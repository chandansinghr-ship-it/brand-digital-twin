{
  "name": "@workspace/api-server",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "export NODE_ENV=development && pnpm run build && pnpm run start",
    "evals": "tsx ./src/evals.ts",
    "test:user-brief": "node --test --import tsx ./src/lib/userBrief/userBrief.test.ts",
    "test:dish-rationale": "node --test --import tsx ./src/lib/dishRationale.test.ts",
    "test:meal-planner": "node --test --import tsx ./src/lib/mealPlanner.test.ts",
    "test:community": "node --test --import tsx ./src/lib/community/community.test.ts",
    "evals:menu-copy": "tsx ./src/lib/menuCopy.eval.ts",
    "build": "node ./build.mjs",
    "start": "node --enable-source-maps ./dist/index.mjs",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@ai-sdk/google": "^3.0.67",
    "@google-cloud/storage": "^7.19.0",
    "@google/genai": "^1.44.0",
    "@opentelemetry/api": "^1.9.1",
    "@workspace/api-zod": "workspace:*",
    "@workspace/db": "workspace:*",
    "@workspace/integrations-gemini-ai": "workspace:*",
    "@workspace/menu-catalog": "workspace:*",
    "ai": "^6.0.175",
    "bullmq": "^5.76.6",
    "cookie-parser": "^1.4.7",
    "cors": "^2",
    "drizzle-orm": "catalog:",
    "express": "^5",
    "ioredis": "^5.10.1",
    "nodemailer": "^8.0.7",
    "openid-client": "^6.1.7",
    "p-limit": "^7.3.0",
    "p-retry": "^7.1.1",
    "pino": "^9",
    "pino-http": "^10",
    "sharp": "^0.34.5",
    "socket.io": "^4.8.3",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "catalog:",
    "@types/nodemailer": "^8.0.0",
    "esbuild": "^0.27.3",
    "esbuild-plugin-pino": "^2.3.3",
    "pino-pretty": "^13",
    "thread-stream": "3.1.0",
    "tsx": "catalog:"
  }
}
